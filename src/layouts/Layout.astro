---
import '../styles/global.css';
import { defaultLang, siteConfig, translations, seo } from '../data/content';
import type { Lang } from '../data/content';

interface Props {
  title: string;
  titleKey?: string;
  lang?: Lang;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  pageType?: 'home' | 'about' | 'services' | 'contact';
}

const {
  title,
  titleKey,
  lang = defaultLang,
  description,
  ogImage,
  canonicalUrl,
  pageType,
} = Astro.props;
const currentYear = new Date().getFullYear();
const t = translations[lang];
const currentSeo = pageType ? seo[pageType][lang] : null;
const pageDescription =
  description ?? currentSeo?.description ?? (t as any).tagline ?? '';
const pageTitle = title ?? currentSeo?.title ?? siteConfig.name;
const canonical = canonicalUrl ?? `${seo.global.siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage ?? seo.global.defaultOgImage;
const socialLinks = [
  { label: 'Facebook', href: siteConfig.social.facebook },
  { label: 'Instagram', href: siteConfig.social.instagram },
  { label: 'LinkedIn', href: siteConfig.social.linkedin },
  { label: 'WhatsApp', href: siteConfig.social.whatsapp },
].filter((item) => item.href);
const serializedTranslations = JSON.stringify(translations).replaceAll(
  '<',
  '\\u003c'
);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="theme-color" content={seo.global.themeColor} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={`${seo.global.siteUrl}${ogImageUrl}`} />
    <meta property="og:site_name" content={seo.global.siteName} />
    <meta property="og:locale" content={lang === 'ms' ? 'ms_MY' : 'en_US'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={`${seo.global.siteUrl}${ogImageUrl}`} />

    <title>{pageTitle}</title>
  </head>
  <body class="bg-white text-gray-900" data-page-title-key={titleKey}>
    <header
      class="fixed top-0 w-full bg-white/95 backdrop-blur-sm shadow-sm z-50"
    >
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <a href="/" class="text-xl font-bold text-primary-600">
            {siteConfig.name}
          </a>

          {/* Desktop Navigation */}
          <div class="hidden md:flex space-x-8">
            <a
              href="/"
              class="text-gray-700 hover:text-primary-600 transition-colors"
              data-i18n="nav.home">{t.nav.home}</a
            >
            <a
              href="/about"
              class="text-gray-700 hover:text-primary-600 transition-colors"
              data-i18n="nav.about">{t.nav.about}</a
            >
            <a
              href="/services"
              class="text-gray-700 hover:text-primary-600 transition-colors"
              data-i18n="nav.services">{t.nav.services}</a
            >
            <a
              href="/contact"
              class="text-gray-700 hover:text-primary-600 transition-colors"
              data-i18n="nav.contact">{t.nav.contact}</a
            >
          </div>

          {/* Desktop Right Section */}
          <div class="hidden md:flex items-center space-x-4">
            <a
              id="lang-toggle"
              href={`?lang=${lang === 'ms' ? 'en' : 'ms'}`}
              class="text-sm font-medium text-gray-600 hover:text-primary-600 transition-colors border border-gray-300 rounded px-3 py-1"
              aria-label="Toggle language"
            >
              <span id="lang-label">{lang === 'ms' ? 'EN' : 'MS'}</span>
            </a>
            <a
              href="/contact"
              class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 transition-colors"
              data-i18n="cta.button"
            >
              {t.cta.button}
            </a>
          </div>

          {/* Mobile Menu Button */}
          <button
            id="mobile-menu-btn"
            class="md:hidden p-2 rounded-lg text-gray-700 hover:text-primary-600 hover:bg-gray-100 transition-colors"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-menu-drawer"
          >
            <svg
              id="menu-icon"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-6 h-6"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
            </svg>
            <svg
              id="close-icon"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-6 h-6 hidden"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      </nav>

      {/* Mobile Menu Drawer */}
      <div
        id="mobile-menu-drawer"
        class="fixed inset-0 z-50 md:hidden"
        aria-hidden="true"
      >
        {/* Backdrop */}
        <div
          id="mobile-menu-backdrop"
          class="absolute inset-0 bg-black/50 opacity-0 transition-opacity duration-300 ease-out"
        >
        </div>

        {/* Drawer Panel */}
        <div
          id="mobile-menu-panel"
          class="absolute right-0 top-0 h-full w-72 max-w-[80vw] bg-white shadow-2xl transform translate-x-full transition-transform duration-300 ease-out"
        >
          <div class="flex flex-col h-full">
            {/* Drawer Header */}
            <div
              class="flex items-center justify-between p-4 border-b border-gray-200"
            >
              <span
                class="text-lg font-semibold text-gray-900"
                data-i18n="language">{t.language}</span
              >
              <button
                id="mobile-menu-close"
                class="p-2 rounded-lg text-gray-700 hover:text-primary-600 hover:bg-gray-100 transition-colors"
                aria-label="Close menu"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-6 h-6"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>

            {/* Drawer Navigation Links */}
            <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto">
              <a
                href="/"
                class="block px-4 py-3 rounded-lg text-gray-700 hover:text-primary-600 hover:bg-gray-50 transition-colors text-base font-medium"
                data-i18n="nav.home"
              >
                {t.nav.home}
              </a>
              <a
                href="/about"
                class="block px-4 py-3 rounded-lg text-gray-700 hover:text-primary-600 hover:bg-gray-50 transition-colors text-base font-medium"
                data-i18n="nav.about"
              >
                {t.nav.about}
              </a>
              <a
                href="/services"
                class="block px-4 py-3 rounded-lg text-gray-700 hover:text-primary-600 hover:bg-gray-50 transition-colors text-base font-medium"
                data-i18n="nav.services"
              >
                {t.nav.services}
              </a>
              <a
                href="/contact"
                class="block px-4 py-3 rounded-lg text-gray-700 hover:text-primary-600 hover:bg-gray-50 transition-colors text-base font-medium"
                data-i18n="nav.contact"
              >
                {t.nav.contact}
              </a>
            </nav>

            {/* Drawer Footer - Language Toggle & CTA */}
            <div class="p-4 border-t border-gray-200 space-y-3">
              {/* Mobile Language Toggle */}
              <a
                id="mobile-lang-toggle"
                href={`?lang=${lang === 'ms' ? 'en' : 'ms'}`}
                class="w-full flex items-center justify-center gap-2 px-4 py-3 rounded-lg border border-gray-300 text-gray-700 hover:text-primary-600 hover:border-primary-600 transition-colors"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-5 h-5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"
                  ></path>
                </svg>
                <span id="mobile-lang-label"
                  >{lang === 'ms' ? 'English' : 'Bahasa Melayu'}</span
                >
              </a>

              {/* Mobile CTA Button */}
              <a
                href="/contact"
                class="block w-full text-center px-4 py-3 rounded-lg bg-primary-600 text-white font-medium hover:bg-primary-700 transition-colors"
                data-i18n="cta.button"
              >
                {t.cta.button}
              </a>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main class="pt-16">
      <slot />
    </main>

    <footer class="bg-gray-900 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div
          class:list={[
            'grid grid-cols-1 gap-8',
            socialLinks.length > 0 ? 'md:grid-cols-4' : 'md:grid-cols-3',
          ]}
        >
          <div>
            <h3 class="text-lg font-semibold mb-4">{siteConfig.name}</h3>
            <p class="text-gray-400" data-i18n="footer.description">
              {t.footer.description}
            </p>
          </div>
          <div>
            <h3
              class="text-lg font-semibold mb-4"
              data-i18n="footer.quickLinks"
            >
              {t.footer.quickLinks}
            </h3>
            <ul class="space-y-2">
              <li>
                <a
                  href="/"
                  class="text-gray-400 hover:text-white transition-colors"
                  data-i18n="nav.home">{t.nav.home}</a
                >
              </li>
              <li>
                <a
                  href="/about"
                  class="text-gray-400 hover:text-white transition-colors"
                  data-i18n="nav.about">{t.nav.about}</a
                >
              </li>
              <li>
                <a
                  href="/services"
                  class="text-gray-400 hover:text-white transition-colors"
                  data-i18n="nav.services">{t.nav.services}</a
                >
              </li>
              <li>
                <a
                  href="/contact"
                  class="text-gray-400 hover:text-white transition-colors"
                  data-i18n="nav.contact">{t.nav.contact}</a
                >
              </li>
            </ul>
          </div>
          {
            socialLinks.length > 0 && (
              <div>
                <h3
                  class="text-lg font-semibold mb-4"
                  data-i18n="footer.social"
                >
                  {t.footer.social}
                </h3>
                <ul class="space-y-2">
                  {socialLinks.map((social) => (
                    <li>
                      <a
                        href={social.href}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors"
                        aria-label={social.label}
                      >
                        {social.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )
          }
          <div>
            <h3 class="text-lg font-semibold mb-4" data-i18n="footer.contact">
              {t.footer.contact}
            </h3>
            <p class="text-gray-400">{siteConfig.address}</p>
            <p class="text-gray-400">{siteConfig.phone}</p>
            <p class="text-gray-400">{siteConfig.email}</p>
          </div>
        </div>
        <div
          class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-400"
        >
          <span data-i18n="footer.copyright">
            © {currentYear}
            {siteConfig.name}. {t.footer.copyright}
          </span>
        </div>
      </div>
    </footer>

    <script
      is:inline
      define:vars={{
        translationsData: serializedTranslations,
        year: currentYear,
      }}
    >
      // Translations data - injected from server
      // @ts-expect-error - translationsData is injected via define:vars
      const translations = JSON.parse(translationsData);
      const currentYear = year;

      const STORAGE_KEY = 'nslc-lang';

      function formatTranslation(value) {
        return value.replaceAll('{year}', String(currentYear));
      }

      function getStoredLang() {
        const stored = localStorage.getItem(STORAGE_KEY);
        return stored === 'en' ? 'en' : 'ms';
      }

      function setStoredLang(lang) {
        localStorage.setItem(STORAGE_KEY, lang);
      }

      function updatePageLang(lang) {
        const t = translations[lang];
        if (!t) return;

        document.documentElement.lang = lang;

        // Update all elements with data-i18n attribute
        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          if (!key) return;

          const value = key.split('.').reduce((acc, part) => {
            if (acc && typeof acc === 'object') {
              return acc[part];
            }
            return undefined;
          }, t);

          if (typeof value === 'string') {
            el.textContent = formatTranslation(value);
          }
        });

        // Update document title when a localized page title is provided.
        const titleKey = document.body.getAttribute('data-page-title-key');
        if (titleKey) {
          const titleValue = titleKey.split('.').reduce((acc, part) => {
            if (acc && typeof acc === 'object') {
              return acc[part];
            }
            return undefined;
          }, t);

          if (typeof titleValue === 'string') {
            document.title = `${formatTranslation(titleValue)} | NS Land Consultant`;
          }
        }

        // Update button labels
        const langLabel = document.getElementById('lang-label');
        if (langLabel) {
          langLabel.textContent = lang === 'ms' ? 'EN' : 'MS';
        }

        // Update mobile language toggle label
        const mobileLangLabel = document.getElementById('mobile-lang-label');
        if (mobileLangLabel) {
          mobileLangLabel.textContent =
            lang === 'ms' ? 'English' : 'Bahasa Melayu';
        }
      }

      // Mobile Menu functionality - wrapped in DOMContentLoaded to ensure elements exist
      function initMobileMenu() {
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenuDrawer = document.getElementById('mobile-menu-drawer');
        const mobileMenuBackdrop = document.getElementById(
          'mobile-menu-backdrop'
        );
        const mobileMenuPanel = document.getElementById('mobile-menu-panel');
        const mobileMenuClose = document.getElementById('mobile-menu-close');
        const menuIcon = document.getElementById('menu-icon');
        const closeIcon = document.getElementById('close-icon');

        if (
          !mobileMenuBtn ||
          !mobileMenuDrawer ||
          !mobileMenuBackdrop ||
          !mobileMenuPanel
        ) {
          console.error('Mobile menu elements not found');
          return;
        }

        let isMenuOpen = false;

        function openMobileMenu() {
          isMenuOpen = true;

          mobileMenuDrawer.setAttribute('aria-hidden', 'false');
          mobileMenuBtn.setAttribute('aria-expanded', 'true');

          // Show backdrop
          mobileMenuBackdrop.classList.remove('opacity-0');
          mobileMenuBackdrop.classList.add('opacity-100');

          // Slide in panel
          mobileMenuPanel.classList.remove('translate-x-full');
          mobileMenuPanel.classList.add('translate-x-0');

          // Toggle icons
          menuIcon?.classList.add('hidden');
          closeIcon?.classList.remove('hidden');

          // Prevent body scroll
          document.body.style.overflow = 'hidden';
        }

        function closeMobileMenu() {
          isMenuOpen = false;

          mobileMenuDrawer.setAttribute('aria-hidden', 'true');
          mobileMenuBtn.setAttribute('aria-expanded', 'false');

          // Hide backdrop
          mobileMenuBackdrop.classList.remove('opacity-100');
          mobileMenuBackdrop.classList.add('opacity-0');

          // Slide out panel
          mobileMenuPanel.classList.remove('translate-x-0');
          mobileMenuPanel.classList.add('translate-x-full');

          // Toggle icons
          menuIcon?.classList.remove('hidden');
          closeIcon?.classList.add('hidden');

          // Restore body scroll
          document.body.style.overflow = '';
        }

        // Toggle menu on hamburger button click
        mobileMenuBtn.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          if (isMenuOpen) {
            closeMobileMenu();
          } else {
            openMobileMenu();
          }
        });

        // Close on X button
        mobileMenuClose?.addEventListener('click', function (e) {
          e.preventDefault();
          closeMobileMenu();
        });

        // Close on backdrop click
        mobileMenuBackdrop.addEventListener('click', function (e) {
          e.preventDefault();
          closeMobileMenu();
        });

        // Close menu on escape key
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && isMenuOpen) {
            closeMobileMenu();
          }
        });

        // Close menu when clicking a nav link (optional - for same-page navigation)
        const drawerNavLinks = mobileMenuDrawer.querySelectorAll('a');
        drawerNavLinks.forEach(function (link) {
          link.addEventListener('click', function () {
            closeMobileMenu();
          });
        });
      }

      // Initialize when DOM is ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initMobileMenu);
      } else {
        initMobileMenu();
      }

      // Initialize with server-rendered language (from prop)
      const initialLang = '{lang}';
      if (initialLang && (initialLang === 'ms' || initialLang === 'en')) {
        // Use server-rendered language as initial state
        document.documentElement.lang = initialLang;
      }

      // Then check localStorage for user preference (client-side only)
      const storedLang = getStoredLang();
      if (storedLang !== initialLang) {
        // If stored language differs from server language, update the page
        updatePageLang(storedLang);
      } else {
        // Just update the UI labels
        updatePageLang(storedLang);
      }

      // Desktop language toggle button
      const langToggle = document.getElementById('lang-toggle');
      if (langToggle) {
        langToggle.addEventListener('click', () => {
          const newLang = getStoredLang() === 'ms' ? 'en' : 'ms';
          setStoredLang(newLang);
          updatePageLang(newLang);
        });
      }

      // Mobile language toggle button
      const mobileLangToggle = document.getElementById('mobile-lang-toggle');
      if (mobileLangToggle) {
        mobileLangToggle.addEventListener('click', () => {
          const newLang = getStoredLang() === 'ms' ? 'en' : 'ms';
          setStoredLang(newLang);
          updatePageLang(newLang);
        });
      }

      // Scroll-reveal animations using IntersectionObserver
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px',
        }
      );

      // Observe all elements with the 'reveal' class
      document.querySelectorAll('.reveal').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
