---
import '../styles/global.css';
import { defaultLang, siteConfig, translations } from '../data/content';
import type { Lang } from '../data/content';

interface Props {
  title: string;
  titleKey?: string;
  lang?: Lang;
  description?: string;
}

const { title, titleKey, lang = defaultLang, description } = Astro.props;
const currentYear = new Date().getFullYear();
const pageDescription = description ?? translations[lang].tagline;
const serializedTranslations = JSON.stringify(translations).replaceAll(
  '<',
  '\\u003c'
);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | {siteConfig.name}</title>
  </head>
  <body class="bg-white text-gray-900" data-page-title-key={titleKey}>
    <header
      class="fixed top-0 w-full bg-white/95 backdrop-blur-sm shadow-sm z-50"
    >
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <a href="/" class="text-xl font-bold text-primary-600">
            {siteConfig.name}
          </a>
          <div class="hidden md:flex space-x-8">
            <a
              href="/"
              class="text-gray-700 hover:text-primary-600 transition-colors"
              data-i18n="nav.home">Laman Utama</a
            >
            <a
              href="/about"
              class="text-gray-700 hover:text-primary-600 transition-colors"
              data-i18n="nav.about">Tentang Kami</a
            >
            <a
              href="/services"
              class="text-gray-700 hover:text-primary-600 transition-colors"
              data-i18n="nav.services">Perkhidmatan</a
            >
            <a
              href="/contact"
              class="text-gray-700 hover:text-primary-600 transition-colors"
              data-i18n="nav.contact">Hubungi</a
            >
          </div>
          <div class="flex items-center space-x-4">
            <button
              id="lang-toggle"
              class="text-sm font-medium text-gray-600 hover:text-primary-600 transition-colors border border-gray-300 rounded px-3 py-1"
              aria-label="Toggle language"
            >
              <span id="lang-label">EN</span>
            </button>
            <a
              href="/contact"
              class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 transition-colors hidden sm:inline-block"
              data-i18n="nav.contactBtn"
            >
              Hubungi Kami
            </a>
          </div>
        </div>
      </nav>
    </header>

    <main class="pt-16">
      <slot />
    </main>

    <footer class="bg-gray-900 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-lg font-semibold mb-4">{siteConfig.name}</h3>
            <p class="text-gray-400" data-i18n="footer.description">
              Perkhidmatan perundingan tanah profesional membantu pelanggan
              menavigasi landskap hartanah Malaysia dengan keyakinan.
            </p>
          </div>
          <div>
            <h3
              class="text-lg font-semibold mb-4"
              data-i18n="footer.quickLinks"
            >
              Pautan Pantas
            </h3>
            <ul class="space-y-2">
              <li>
                <a
                  href="/"
                  class="text-gray-400 hover:text-white transition-colors"
                  data-i18n="nav.home">Laman Utama</a
                >
              </li>
              <li>
                <a
                  href="/about"
                  class="text-gray-400 hover:text-white transition-colors"
                  data-i18n="nav.about">Tentang Kami</a
                >
              </li>
              <li>
                <a
                  href="/services"
                  class="text-gray-400 hover:text-white transition-colors"
                  data-i18n="nav.services">Perkhidmatan</a
                >
              </li>
              <li>
                <a
                  href="/contact"
                  class="text-gray-400 hover:text-white transition-colors"
                  data-i18n="nav.contact">Hubungi</a
                >
              </li>
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-semibold mb-4" data-i18n="footer.contact">
              Hubungi
            </h3>
            <p class="text-gray-400">{siteConfig.address}</p>
            <p class="text-gray-400">{siteConfig.phone}</p>
            <p class="text-gray-400">{siteConfig.email}</p>
          </div>
        </div>
        <div
          class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-400"
        >
          <span data-i18n="footer.copyright">
            © {currentYear} NS Land Consultant. Hak cipta terpelihara.
          </span>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Translations data
      const translations = { serializedTranslations };
      const currentYear = { currentYear };

      const STORAGE_KEY = 'nslc-lang';

      function formatTranslation(value) {
        return value.replaceAll('{year}', String(currentYear));
      }

      function getStoredLang() {
        const stored = localStorage.getItem(STORAGE_KEY);
        return stored === 'en' ? 'en' : 'ms';
      }

      function setStoredLang(lang) {
        localStorage.setItem(STORAGE_KEY, lang);
      }

      function updatePageLang(lang) {
        const t = translations[lang];
        if (!t) return;

        document.documentElement.lang = lang;

        // Update all elements with data-i18n attribute
        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          if (!key) return;

          const value = key.split('.').reduce((acc, part) => {
            if (acc && typeof acc === 'object') {
              return acc[part];
            }
            return undefined;
          }, t);

          if (typeof value === 'string') {
            el.textContent = formatTranslation(value);
          }
        });

        // Update document title when a localized page title is provided.
        const titleKey = document.body.getAttribute('data-page-title-key');
        if (titleKey) {
          const titleValue = titleKey.split('.').reduce((acc, part) => {
            if (acc && typeof acc === 'object') {
              return acc[part];
            }
            return undefined;
          }, t);

          if (typeof titleValue === 'string') {
            document.title = `${formatTranslation(titleValue)} | NS Land Consultant`;
          }
        }

        // Update button label
        const langLabel = document.getElementById('lang-label');
        if (langLabel) {
          langLabel.textContent = lang === 'ms' ? 'EN' : 'MS';
        }
      }

      // Initialize on page load
      const currentLang = getStoredLang();
      updatePageLang(currentLang);

      // Language toggle button
      const langToggle = document.getElementById('lang-toggle');
      if (langToggle) {
        langToggle.addEventListener('click', () => {
          const newLang = getStoredLang() === 'ms' ? 'en' : 'ms';
          setStoredLang(newLang);
          updatePageLang(newLang);
        });
      }

      // Scroll-reveal animations using IntersectionObserver
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px',
        }
      );

      // Observe all elements with the 'reveal' class
      document.querySelectorAll('.reveal').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
