---
import Layout from '../layouts/Layout.astro';
import { services } from '../data/content';
---

<Layout title="Services">
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Our Services</h1>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Professional land consultancy services to help you navigate Malaysia's property landscape
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {services.map((service) => (
          <div class="bg-gray-50 rounded-xl p-8 hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 bg-primary-100 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h2 class="text-2xl font-semibold text-gray-900 mb-4">{service.title}</h2>
            <p class="text-gray-600">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-primary-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Need Help Choosing a Service?</h2>
      <p class="text-xl text-primary-100 mb-8 max-w-2xl mx-auto">
        Our team is ready to assist you with any questions about our services.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center bg-white text-primary-600 px-6 py-3 rounded-lg text-lg font-medium hover:bg-gray-100 transition-colors"
      >
        Contact Us
      </a>
    </div>
  </section>
</Layout>