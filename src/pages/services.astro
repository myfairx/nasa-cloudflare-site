---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import {
  translations,
  pageHeroes,
  defaultLang,
  type Lang,
} from '../data/content';

// Get language from URL query param or default
const lang: Lang = (Astro.url.searchParams.get('lang') as Lang) || defaultLang;
const t = translations[lang];
const hero = pageHeroes.services[lang];

