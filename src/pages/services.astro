    building:
      'M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm6 12h-2v-2h2v2zm0-4h-2v-2h2v2zm0-4h-2V9h2v2zm0-4h-2V5h2v2zm6 12h-2v-2h2v2zm0-4h-2v-2h2v2zm0-4h-2V9h2v2z',
    users:
      'M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z',
    star: 'M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z',
  };
  return icons[icon] || icons.consulting;
};
---

<Layout
  title={t.nav.services}
  titleKey="nav.services"
  pageType="services"
  lang={lang}
>
  <PageHero
    title={hero.title}
    subtitle={hero.subtitle}
    backgroundImage={pageHeroes.services.backgroundImage}
  />

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          t.services.items.map((service, index) => (
            <div
              class={`reveal bg-gray-50 rounded-xl p-8 hover:shadow-lg transition-shadow delay-${(index % 3) + 1}`}
            >
              <div class="w-14 h-14 bg-primary-100 rounded-xl flex items-center justify-center mb-6">
                <svg
                  class="w-7 h-7 text-primary-600"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d={getIconSvg(service.icon)} />
                </svg>
              </div>
              <h2
                class="text-xl font-semibold text-gray-900 mb-4"
                data-i18n={`services.items.${index}.title`}
              >
                {service.title}
              </h2>
              <p
                class="text-gray-600"
                data-i18n={`services.items.${index}.description`}
              >
                {service.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="reveal py-20 bg-primary-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2
        class="text-3xl md:text-4xl font-bold text-white mb-6"
        data-i18n="services.helpTitle"
      >
        {t.services.helpTitle}
      </h2>
      <p
        class="text-xl text-primary-100 mb-8 max-w-2xl mx-auto"
        data-i18n="services.helpSubtitle"
      >
        {t.services.helpSubtitle}
      </p>
      <a
        href="/contact"
        class="inline-flex items-center bg-white text-primary-600 px-6 py-3 rounded-lg text-lg font-medium hover:bg-gray-100 transition-colors"
        data-i18n="services.helpButton"
      >
        {t.services.helpButton}
      </a>
    </div>
  </section>
</Layout>
