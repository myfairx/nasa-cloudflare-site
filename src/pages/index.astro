---
import Layout from '../layouts/Layout.astro';
import {
  siteConfig,
  translations,
  defaultLang,
  type Lang,
} from '../data/content';

// Get language from URL query param or default
const lang: Lang = (Astro.url.searchParams.get('lang') as Lang) || defaultLang;
const t = translations[lang];
---

<Layout title={t.nav.home} titleKey="nav.home" pageType="home" lang={lang}>
  <section
    class="reveal relative py-20 lg:py-32 overflow-hidden"
    style="background-image: url('/images/backgrounds/hero-home.webp'); background-size: cover; background-position: center;"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl">
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6"
          style="text-shadow: 2px 2px 4px rgba(0,0,0,0.7), 0 0 20px rgba(0,0,0,0.5);"
          data-i18n="hero.title"
        >
          {t.hero.title}
        </h1>
        <p
          class="text-xl text-white mb-8"
          style="text-shadow: 1px 1px 3px rgba(0,0,0,0.7), 0 0 15px rgba(0,0,0,0.4);"
          data-i18n="hero.subtitle"
        >
          {t.hero.subtitle}
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="/contact"
            class="inline-flex items-center justify-center bg-white text-primary-700 px-6 py-3 rounded-lg text-lg font-medium hover:bg-gray-100 transition-colors shadow-lg"
            data-i18n="hero.cta"
          >
            {t.hero.cta}
          </a>
          <a
            href={siteConfig.social.whatsapp}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center bg-green-600 text-white px-6 py-3 rounded-lg text-lg font-medium hover:bg-green-700 transition-colors shadow-lg"
            data-i18n="cta.whatsappButton"
          >
            {t.cta.whatsappButton}
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="reveal py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2
          class="text-3xl md:text-4xl font-bold text-gray-900 mb-4"
          data-i18n="services.title"
        >
          {t.services.title}
        </h2>
        <p
          class="text-lg text-gray-600 max-w-2xl mx-auto"
          data-i18n="services.subtitle"
        >
          {t.services.subtitle}
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          t.services.items.slice(0, 3).map((service, index) => (
            <div
              class={`bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow reveal delay-${index + 1}`}
            >
              <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
                <svg
                  class="w-6 h-6 text-primary-600"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z" />
                </svg>
              </div>
              <h3
                class="text-xl font-semibold text-gray-900 mb-2"
                data-i18n={`services.items.${index}.title`}
              >
                {service.title}
              </h3>
              <p
                class="text-gray-600"
                data-i18n={`services.items.${index}.description`}
              >
                {service.description}
              </p>
            </div>
          ))
        }
      </div>
      <div class="text-center mt-12">
        <a
          href="/services"
          class="text-primary-600 font-medium hover:text-primary-700 transition-colors"
          data-i18n="services.viewAll"
        >
          {t.services.viewAll}
        </a>
      </div>
    </div>
  </section>

  <section class="reveal py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2
          class="text-3xl md:text-4xl font-bold text-gray-900 mb-4"
          data-i18n="whyUs.title"
        >
          {t.whyUs.title}
        </h2>
        <p
          class="text-lg text-gray-600 max-w-2xl mx-auto"
          data-i18n="whyUs.subtitle"
        >
          {t.whyUs.subtitle}
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {
          t.whyUs.items.map((item, index) => (
            <div
              class={`bg-white rounded-xl p-8 shadow-sm reveal delay-${index + 1}`}
            >
              <h3
                class="text-xl font-semibold text-gray-900 mb-3"
                data-i18n={`whyUs.items.${index}.title`}
              >
                {item.title}
              </h3>
              <p
                class="text-gray-600"
                data-i18n={`whyUs.items.${index}.description`}
              >
                {item.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="reveal py-20 bg-primary-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2
        class="text-3xl md:text-4xl font-bold text-white mb-6"
        data-i18n="cta.title"
      >
        {t.cta.title}
      </h2>
      <p
        class="text-xl text-primary-100 mb-8 max-w-2xl mx-auto"
        data-i18n="cta.subtitle"
      >
        {t.cta.subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center bg-white text-primary-600 px-6 py-3 rounded-lg text-lg font-medium hover:bg-gray-100 transition-colors"
          data-i18n="cta.button"
        >
          {t.cta.button}
        </a>
        <a
          href={siteConfig.social.whatsapp}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center justify-center bg-green-600 text-white px-6 py-3 rounded-lg text-lg font-medium hover:bg-green-700 transition-colors"
          data-i18n="cta.whatsappButton"
        >
          {t.cta.whatsappButton}
        </a>
      </div>
    </div>
  </section>
</Layout>
