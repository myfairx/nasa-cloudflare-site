---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Laman Utama">
  <section
    class="reveal relative bg-gradient-to-br from-primary-50 to-white py-20 lg:py-32"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6"
          data-i18n="hero.title"
        >
          Rakan Perunding Tanah Yang Dipercayai
        </h1>
        <p class="text-xl text-gray-600 mb-8" data-i18n="hero.subtitle">
          Panduan pakar untuk semua keperluan pembangunan tanah dan hartanah
          anda di seluruh Malaysia
        </p>
        <a
          href="/contact"
          class="inline-flex items-center bg-primary-600 text-white px-6 py-3 rounded-lg text-lg font-medium hover:bg-primary-700 transition-colors"
          data-i18n="hero.cta"
        >
          Hubungi Kami
        </a>
      </div>
    </div>
  </section>

  <section class="reveal py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2
          class="text-3xl md:text-4xl font-bold text-gray-900 mb-4"
          data-i18n="services.title"
        >
          Perkhidmatan Kami
        </h2>
        <p
          class="text-lg text-gray-600 max-w-2xl mx-auto"
          data-i18n="services.subtitle"
        >
          Perkhidmatan perundingan tanah komprehensif disesuaikan dengan
          keperluan anda
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Service 1: Consultation -->
        <div
          class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow reveal delay-1"
        >
          <div
            class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-primary-600"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">
            Perundingan Hartanah & Tanah
          </h3>
          <p class="text-gray-600">
            Nasihat jual beli tanah, analisis potensi dan kegunaan tanah, serta
            strategi pelaburan tanah.
          </p>
        </div>

        <!-- Service 2: Sales Management -->
        <div
          class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow reveal delay-2"
        >
          <div
            class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-primary-600"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M16.5 13c-1.2 0-3.07.34-4.5 1-1.43-.67-3.3-1-4.5-1C5.54 13 3.76 13.88 2.75 15H2v2h.75c1.01 1.12 2.79 2 4.75 2 1.2 0 3.07-.34 4.5-1 1.43.67 3.3 1 4.5 1 1.96 0 3.74-.88 4.75-2H22v-2h-.75c-1.01-1.12-2.79-2-4.75-2zm-6.5 2c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">
            Pengurusan Jual Beli Tanah
          </h3>
          <p class="text-gray-600">
            Urusan pemasaran tanah, mencari pembeli dan penjual yang sesuai
            (matching), serta rundingan harga.
          </p>
        </div>

        <!-- Service 3: Inheritance -->
        <div
          class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow reveal delay-3"
        >
          <div
            class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-primary-600"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">
            Pengurusan Tanah Pusaka
          </h3>
          <p class="text-gray-600">
            Urusan faraid dan pembahagian harta, pelantikan pentadbir atau
            wakil, serta penyediaan dokumen pusaka.
          </p>
        </div>
      </div>
      <div class="text-center mt-12">
        <a
          href="/services"
          class="text-primary-600 font-medium hover:text-primary-700 transition-colors"
          data-i18n="services.viewAll"
        >
          Lihat semua perkhidmatan →
        </a>
      </div>
    </div>
  </section>

  <section class="reveal py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2
          class="text-3xl md:text-4xl font-bold text-gray-900 mb-4"
          data-i18n="whyUs.title"
        >
          Mengapa Pilih Kami
        </h2>
        <p
          class="text-lg text-gray-600 max-w-2xl mx-auto"
          data-i18n="whyUs.subtitle"
        >
          Kepakaran dipercayai untuk keperluan tanah dan hartanah anda
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-sm reveal delay-1">
          <h3
            class="text-xl font-semibold text-gray-900 mb-3"
            data-i18n="whyUs.team"
          >
            Pasukan Berpengalaman
          </h3>
          <p class="text-gray-600" data-i18n="whyUs.teamDesc">
            Tahun kepakaran dalam peraturan tanah dan hartanah Malaysia.
          </p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-sm reveal delay-2">
          <h3
            class="text-xl font-semibold text-gray-900 mb-3"
            data-i18n="whyUs.partner"
          >
            Rakan Dipercayai
          </h3>
          <p class="text-gray-600" data-i18n="whyUs.partnerDesc">
            Bina hubungan jangka panjang dengan perkhidmatan telus dan boleh
            dipercayai.
          </p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-sm reveal delay-3">
          <h3
            class="text-xl font-semibold text-gray-900 mb-3"
            data-i18n="whyUs.focus"
          >
            Fokus Pelanggan
          </h3>
          <p class="text-gray-600" data-i18n="whyUs.focusDesc">
            Penyelesaian disesuaikan untuk memenuhi keperluan unik anda.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="reveal py-20 bg-primary-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2
        class="text-3xl md:text-4xl font-bold text-white mb-6"
        data-i18n="cta.title"
      >
        Sedia Untuk Memulakan?
      </h2>
      <p
        class="text-xl text-primary-100 mb-8 max-w-2xl mx-auto"
        data-i18n="cta.subtitle"
      >
        Hubungi kami hari ini untuk perundingan percuma mengenai keperluan tanah
        atau hartanah anda.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center bg-white text-primary-600 px-6 py-3 rounded-lg text-lg font-medium hover:bg-gray-100 transition-colors"
        data-i18n="cta.button"
      >
        Hubungi Kami
      </a>
    </div>
  </section>
</Layout>
