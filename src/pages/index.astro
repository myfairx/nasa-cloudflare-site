---
import Layout from '../layouts/Layout.astro';
import { hero, services, whyUs } from '../data/content';
---

<Layout title="Home">
  <section
    class="reveal relative bg-gradient-to-br from-primary-50 to-white py-20 lg:py-32"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6"
        >
          {hero.title}
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          {hero.subtitle}
        </p>
        <a
          href={hero.ctaHref}
          class="inline-flex items-center bg-primary-600 text-white px-6 py-3 rounded-lg text-lg font-medium hover:bg-primary-700 transition-colors"
        >
          {hero.cta}
        </a>
      </div>
    </div>
  </section>

  <section class="reveal py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Our Services
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Comprehensive land consultancy services tailored to your needs
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {
          services.map((service, index) => (
            <div
              class={`bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow reveal delay-${index + 1}`}
            >
              <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
                <svg
                  class="w-6 h-6 text-primary-600"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                  />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">
                {service.title}
              </h3>
              <p class="text-gray-600">{service.description}</p>
            </div>
          ))
        }
      </div>
      <div class="text-center mt-12">
        <a
          href="/services"
          class="text-primary-600 font-medium hover:text-primary-700 transition-colors"
        >
          View all services →
        </a>
      </div>
    </div>
  </section>

  <section class="reveal py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Why Choose Us
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Trusted expertise for your land and property needs
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {
          whyUs.map((item, index) => (
            <div
              class={`bg-white rounded-xl p-8 shadow-sm reveal delay-${index + 1}`}
            >
              <h3 class="text-xl font-semibold text-gray-900 mb-3">
                {item.title}
              </h3>
              <p class="text-gray-600">{item.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="reveal py-20 bg-primary-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Ready to Get Started?
      </h2>
      <p class="text-xl text-primary-100 mb-8 max-w-2xl mx-auto">
        Contact us today for a free consultation on your land or property needs.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center bg-white text-primary-600 px-6 py-3 rounded-lg text-lg font-medium hover:bg-gray-100 transition-colors"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
