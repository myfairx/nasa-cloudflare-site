---
import Layout from '../layouts/Layout.astro';
import { translations } from '../data/content';

export function getStaticPaths() {
  return [
    { params: {}, props: { lang: 'ms' as const } },
    { params: { lang: 'en' }, props: { lang: 'en' as const } },
  ];
}

const { lang = 'ms' } = Astro.props;
const t = translations[lang];
---

<Layout title={t.nav.about} lang={lang}>
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="reveal text-4xl md:text-5xl font-bold text-gray-900 mb-8">
          {t.about.title}
        </h1>
        <div class="reveal prose prose-lg text-gray-600">
          <p class="mb-6">{t.about.story}</p>
        </div>
        <h2 class="reveal text-2xl font-semibold text-gray-900 mb-4">
          {lang === 'ms' ? 'Nilai Kami' : 'Our Values'}
        </h2>
        <ul class="space-y-3">
          {
            t.about.values.map((value: string, index: number) => (
              <li
                class={`reveal flex items-center text-gray-600 delay-${index + 1}`}
              >
                <svg
                  class="w-5 h-5 text-primary-600 mr-3"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                    clip-rule="evenodd"
                  />
                </svg>
                {value}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>
</Layout>
